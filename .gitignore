# Lateos .gitignore — Secret Protection

# ===== SECRETS — NEVER COMMIT THESE =====
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ecdsa
*_ed25519
credentials
credentials.json
*secret*
*credential*
*token*
.aws/

# ===== AWS CDK =====
cdk.out/
.cdk.staging/
cdk.context.json
!cdk.context.json.example

# ===== AWS SAM =====
.aws-sam/
samconfig.toml

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ===== Testing =====
.coverage
.pytest_cache/
htmlcov/
.tox/
.hypothesis/

# ===== LocalStack =====
.localstack/
volume/
localstack-data/

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ===== Logs =====
*.log
logs/

