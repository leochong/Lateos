# Lateos .gitignore — Secret Protection

# ===== SECRETS — NEVER COMMIT THESE =====
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ecdsa
*_ed25519
credentials
credentials.json
*credential*
*token*
*secret*
!.secrets.baseline  # Exception: baseline file MUST be committed
.aws/

# ===== AWS CDK =====
cdk.out/
.cdk.staging/
cdk.context.json
!cdk.context.json.example

# ===== AWS SAM =====
.aws-sam/
samconfig.toml

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.venv*/
venv/
venv*/
ENV/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ===== Testing =====
.coverage
.pytest_cache/
htmlcov/
.tox/
.hypothesis/

# ===== LocalStack =====
.localstack/
volume/
localstack-data/
mnt/

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ===== Logs =====
*.log
logs/

# ===== Node.js (for CDK) =====
node_modules/
package-lock.json
yarn.lock

# ===== Terraform (if ever used) =====
*.tfstate
*.tfstate.backup
.terraform/

# ===== Security Scanning =====
# Note: .secrets.baseline should be committed (it's the detection baseline, not actual secrets)

# ===== Misc =====
.tmp/
tmp/
temp/

# ===== Temporary/Planning Files =====
# Root-level temporary test files
/test_*.py

# Old status/planning documents
*-STATUS.md
*-COMPLETE.md
*-PLAN.md
*-kickstart*.md
*-project-tree*.md
*-complete-*.tar.gz
*-SUMMARY.md

# Exceptions (keep these specific files)
!STATUS.md
!tests/**/test_*.py
