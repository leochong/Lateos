# Lateos — Environment Configuration Template
#
# ⚠️  WARNING: This file contains ONLY placeholders, NOT real values!
# ⚠️  Real secrets go in AWS Secrets Manager, NEVER in .env files
# ⚠️  Copy this to .env.local for LOCAL DEVELOPMENT ONLY
# ⚠️  NEVER commit .env or .env.local to version control
#
# For LocalStack development, use mock values like "test" or "mock-key"

# ===== AWS Configuration (Not Secrets) =====
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000  # LocalStack uses 000000000000
AWS_PROFILE=localstack        # For local development

# ===== CDK Configuration =====
CDK_ENVIRONMENT=dev           # dev | staging | prod
CDK_MONTHLY_BUDGET_USD=10     # Cost kill switch threshold
CDK_LOG_RETENTION_DAYS=90

# ===== Bedrock Configuration =====
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# ===== LocalStack Configuration =====
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCALSTACK_HOSTNAME=localhost
EDGE_PORT=4566

# ===== Secrets Manager Paths (values stored in AWS, not here) =====
# These are KEY PATHS only — actual secrets retrieved at runtime
SECRETS_PATH_PREFIX=lateos/dev/

# Example secret paths (NEVER put actual values here):
# lateos/dev/telegram       → { "bot_token": "..." }
# lateos/dev/slack          → { "signing_secret": "...", "bot_token": "..." }
# lateos/dev/twilio         → { "account_sid": "...", "auth_token": "..." }
# lateos/dev/email/gmail    → { "client_id": "...", "client_secret": "..." }

# ===== DynamoDB Configuration =====
DYNAMODB_TABLE_NAME_PREFIX=lateos-dev-
DYNAMODB_MEMORY_TABLE=lateos-dev-memory
DYNAMODB_AUDIT_TABLE=lateos-dev-audit

# ===== S3 Configuration =====
S3_BUCKET_PREFIX=lateos-dev-
S3_FILES_BUCKET=lateos-dev-files

# ===== API Gateway Configuration =====
API_GATEWAY_STAGE=dev

# ===== Cognito Configuration =====
COGNITO_USER_POOL_NAME=lateos-dev-users
COGNITO_MFA_REQUIRED=true

# ===== Step Functions Configuration =====
STATE_MACHINE_TIMEOUT_SECONDS=300  # 5 minutes for Express workflows

# ===== Lambda Configuration =====
LAMBDA_MEMORY_MB=512
LAMBDA_TIMEOUT_SECONDS=30
LAMBDA_RESERVED_CONCURRENCY=10     # Cost protection

# ===== Observability =====
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
POWERTOOLS_SERVICE_NAME=lateos
POWERTOOLS_METRICS_NAMESPACE=Lateos

# ===== Security Configuration =====
WAF_ENABLED=true
CLOUDTRAIL_ENABLED=true
GUARDDUTY_ENABLED=true

# ===== Cost Protection =====
COST_ALERT_THRESHOLD_USD=8         # Alert at 80% of budget
COST_KILL_SWITCH_THRESHOLD_USD=10  # Kill at 100%

# ===== Local Development Flags =====
IS_LOCAL_DEVELOPMENT=true
SKIP_SECRET_VALIDATION=false       # Never skip in production!
